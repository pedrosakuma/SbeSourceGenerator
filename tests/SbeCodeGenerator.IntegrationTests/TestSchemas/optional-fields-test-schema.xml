<?xml version="1.0" encoding="UTF-8"?>
<sbe:messageSchema xmlns:sbe="http://fixprotocol.io/2016/sbe"
                   package="optional_test"
                   id="5"
                   version="0"
                   semanticVersion="1.0"
                   description="Schema test for optional fields encoding/decoding"
                   byteOrder="littleEndian">
    <types>
        <composite name="MessageHeader" description="Template ID and length of message root">
            <type name="blockLength" primitiveType="uint16"/>
            <type name="templateId" primitiveType="uint16"/>
            <type name="schemaId" primitiveType="uint16"/>
            <type name="version" primitiveType="uint16"/>
        </composite>

        <!-- NULL types for optional fields - using standard SBE NULL types -->
        <type name="Int8NULL" primitiveType="int8" presence="optional" nullValue="-128"/>
        <type name="Int16NULL" primitiveType="int16" presence="optional" nullValue="-32768"/>
        <type name="Int32NULL" primitiveType="int32" presence="optional" nullValue="-2147483648"/>
        <type name="Int64NULL" primitiveType="int64" presence="optional" nullValue="-9223372036854775808"/>
        <type name="UInt8NULL" primitiveType="uint8" presence="optional" nullValue="255"/>
        <type name="UInt16NULL" primitiveType="uint16" presence="optional" nullValue="65535"/>
        <type name="UInt32NULL" primitiveType="uint32" presence="optional" nullValue="4294967295"/>
        <type name="UInt64NULL" primitiveType="uint64" presence="optional" nullValue="18446744073709551615"/>

        <!-- Required primitive types for comparison -->
        <type name="OrderId" primitiveType="int64" minValue="1"/>
        <type name="Price" primitiveType="int64" minValue="0"/>

        <!-- Enum type -->
        <enum name="OrderSide" encodingType="uint8">
            <validValue name="Buy">1</validValue>
            <validValue name="Sell">2</validValue>
        </enum>
    </types>

    <!-- Simpler message for basic testing -->
    <sbe:message name="SimpleOptional" id="41" description="Simple message with one optional field">
        <field name="id" id="1" type="int64" description="Required ID"/>
        <field name="optionalValue" id="2" type="Int64NULL" description="Optional value"/>
    </sbe:message>

    <!-- Comprehensive message with all optional types -->
    <sbe:message name="AllOptionalTypes" id="42" description="Message with all optional primitive types">
        <field name="id" id="1" type="int64" description="Required ID"/>
        <field name="optInt8" id="2" type="Int8NULL" description="Optional int8"/>
        <field name="optInt16" id="3" type="Int16NULL" description="Optional int16"/>
        <field name="optInt32" id="4" type="Int32NULL" description="Optional int32"/>
        <field name="optInt64" id="5" type="Int64NULL" description="Optional int64"/>
        <field name="optUInt8" id="6" type="UInt8NULL" description="Optional uint8"/>
        <field name="optUInt16" id="7" type="UInt16NULL" description="Optional uint16"/>
        <field name="optUInt32" id="8" type="UInt32NULL" description="Optional uint32"/>
        <field name="optUInt64" id="9" type="UInt64NULL" description="Optional uint64"/>
    </sbe:message>
</sbe:messageSchema>

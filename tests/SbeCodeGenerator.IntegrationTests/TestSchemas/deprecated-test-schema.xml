<?xml version="1.0" encoding="UTF-8"?>
<sbe:messageSchema xmlns:sbe="http://fixprotocol.io/2016/sbe"
                   package="deprecated_test"
                   id="4"
                   version="2"
                   semanticVersion="2.0"
                   description="Schema test for deprecated fields"
                   byteOrder="littleEndian">
    <types>
        <composite name="MessageHeader" description="Template ID and length of message root">
            <type name="blockLength" primitiveType="uint16"/>
            <type name="templateId" primitiveType="uint16"/>
            <type name="schemaId" primitiveType="uint16"/>
            <type name="version" primitiveType="uint16"/>
        </composite>

        <type name="OrderId" primitiveType="int64" minValue="1"/>
        <type name="Price" primitiveType="int64" minValue="0"/>
    </types>

    <!-- Message with deprecated fields -->
    <sbe:message name="OrderWithDeprecated" id="30" description="Order message with deprecated fields">
        <field name="orderId" id="1" type="OrderId" description="Order ID - active field"/>
        <field name="oldPrice" id="2" type="Price" deprecated="2" description="Old price field - deprecated"/>
        <field name="price" id="3" type="Price" description="New price field - active"/>
        <field name="legacyQuantity" id="4" type="int64" sinceVersion="1" deprecated="2" description="Legacy quantity - deprecated since v2"/>
        <field name="quantity" id="5" type="int64" sinceVersion="2" description="New quantity field"/>
        <field name="optionalField" id="6" type="int64" presence="optional" deprecated="1" description="Optional deprecated field"/>
    </sbe:message>
</sbe:messageSchema>

<?xml version="1.0" encoding="UTF-8"?>
<sbe:messageSchema xmlns:sbe="http://fixprotocol.io/2016/sbe"
                   package="HighPerf.MarketData"
                   id="1"
                   version="0"
                   semanticVersion="1.0"
                   description="High-performance market data schema"
                   byteOrder="littleEndian">
    <types>
        <composite name="MessageHeader">
            <type name="blockLength" primitiveType="uint16"/>
            <type name="templateId" primitiveType="uint16"/>
            <type name="schemaId" primitiveType="uint16"/>
            <type name="version" primitiveType="uint16"/>
        </composite>

        <type name="Price" primitiveType="int64" description="Price with 4 decimal places" minValue="0"/>
        <type name="Quantity" primitiveType="int64" description="Quantity" minValue="0"/>
        <type name="InstrumentId" primitiveType="uint32"/>
        <type name="Timestamp" primitiveType="uint64"/>
        
        <enum name="Side" encodingType="uint8">
            <validValue name="Buy">0</validValue>
            <validValue name="Sell">1</validValue>
        </enum>

        <composite name="GroupSizeEncoding">
            <type name="blockLength" primitiveType="uint16"/>
            <type name="numInGroup" primitiveType="uint16"/>
        </composite>
    </types>

    <!-- Simple quote message -->
    <sbe:message name="Quote" id="1" description="Best bid/ask quote">
        <field name="instrumentId" id="1" type="InstrumentId"/>
        <field name="timestamp" id="2" type="Timestamp"/>
        <field name="bidPrice" id="3" type="Price"/>
        <field name="bidQuantity" id="4" type="Quantity"/>
        <field name="askPrice" id="5" type="Price"/>
        <field name="askQuantity" id="6" type="Quantity"/>
    </sbe:message>

    <!-- Trade message -->
    <sbe:message name="Trade" id="2" description="Trade execution">
        <field name="instrumentId" id="1" type="InstrumentId"/>
        <field name="timestamp" id="2" type="Timestamp"/>
        <field name="tradeId" id="3" type="uint64"/>
        <field name="price" id="4" type="Price"/>
        <field name="quantity" id="5" type="Quantity"/>
        <field name="side" id="6" type="Side"/>
    </sbe:message>

    <!-- Market depth snapshot -->
    <sbe:message name="DepthSnapshot" id="3" description="Market depth snapshot">
        <field name="instrumentId" id="1" type="InstrumentId"/>
        <field name="timestamp" id="2" type="Timestamp"/>
        
        <group name="bids" id="3" dimensionType="GroupSizeEncoding">
            <field name="price" id="4" type="Price"/>
            <field name="quantity" id="5" type="Quantity"/>
            <field name="orderCount" id="6" type="uint32"/>
        </group>
        
        <group name="asks" id="7" dimensionType="GroupSizeEncoding">
            <field name="price" id="8" type="Price"/>
            <field name="quantity" id="9" type="Quantity"/>
            <field name="orderCount" id="10" type="uint32"/>
        </group>
    </sbe:message>
</sbe:messageSchema>
